# Copie para .env e preencha conforme necessário (NÃO comite o .env).

# --- Coletor AIS (server/aisCollector.ts) ---
# Chave grátis do aisstream.io (login GitHub): https://aisstream.io
AISSTREAM_API_KEY=
# Porta HTTP do coletor (padrão 8787)
# PORT=8787

# --- Front-end (Vite) ---
# Aponta o app para a API. Em dev/preview/Vercel/Netlify o padrão /api/dados já
# funciona. Use isto para consumir o coletor AIS ou um backend externo:
# VITE_API_URL=http://localhost:8787/api/dados
# Intervalo de polling do front-end, em ms (padrão 5000)
# VITE_POLL_INTERVAL=5000
# Fator do botão "Acelerar" (fast-forward da simulação, padrão 8)
# VITE_ACELERACAO=8
